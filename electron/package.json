{
  "name": "taskflow",
  "version": "1.0.0",
  "description": "TaskFlow — Kanban Task Manager",
  "main": "main.js",
  "author": "Vynimaciell",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.vynimaciell.taskflow",
    "productName": "TaskFlow",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "dist/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "shortcutName": "TaskFlow"
    }
  }
}